# Port for Ollama API (Backend)
OLLAMA_PORT=11434

# Port for Open WebUI Frontend (Frontend)
WEBUI_PORT=3000

# Default model to download and run
# DEFAULT_MODEL=qwen2.5-coder:7b
# DEFAULT_MODEL=llama3:latest           
DEFAULT_MODEL=gemma4:12b

# Base URL for Ollama API (used by frontend to communicate with backend)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- OpenLIT Monitoring Stack Configuration ---
# Port for OpenLIT Dashboard (defaults to 3005 to avoid conflict with WebUI)
OPENLIT_PORT=3005

# Enable OpenTelemetry instrumentation in Open WebUI (set to true to enable)
ENABLE_OTEL=false

# OTLP Collector endpoint (where WebUI sends metrics/traces)
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318
